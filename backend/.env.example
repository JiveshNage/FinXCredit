# -------------------------------------------------------------
# CreditBridge AI (FinXCredit) - Environment Configuration
# -------------------------------------------------------------

# Database
# Production URL (Render/AWS): postgresql://user:password@hostname:5432/dbname
DATABASE_URL=postgresql://postgres:password@localhost:5432/finx

# Authentication
# Must match a secure 256-bit secret string in production
JWT_SECRET_KEY=your_super_secret_jwt_key_here
OTP_EXPIRY_MINUTES=10

# Third-Party APIs (Optional / Mocked in dev)
SENDGRID_API_KEY=SG.your_sendgrid_api_key...
TWILIO_ACCOUNT_SID=ACyour_twilio_sid...
TWILIO_AUTH_TOKEN=your_twilio_auth_token...
